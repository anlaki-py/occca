{
  "name": "occca",
  "version": "1.0.0",
  "description": "OpenAI Compatible CLI Coding Agent - A minimal agentic coding CLI using OpenAI-compatible APIs",
  "type": "module",
  "main": "dist/entrypoints/cli.js",
  "bin": {
    "occca": "./bin/occca.js"
  },
  "scripts": {
    "dev": "node --no-deprecation --import tsx/esm src/entrypoints/cli.ts",
    "build": "tsc",
    "build:static": "esbuild src/entrypoints/cli.ts --bundle --platform=node --outfile=dist/bundle.cjs --format=cjs && pkg dist/bundle.cjs --targets node20-win-x64,node20-linux-x64 --out-path dist/bin && mv dist/bin/bundle-win.exe dist/bin/occca-win.exe && mv dist/bin/bundle-linux dist/bin/occca-linux",
    "start": "node --no-deprecation dist/entrypoints/cli.js",
    "preview": "tsx src/entrypoints/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "coding-agent",
    "openai",
    "ai",
    "developer-tools"
  ],
  "license": "MIT",
  "pkg": {
    "scripts": "dist/bundle.cjs",
    "assets": [],
    "targets": ["node20-win-x64", "node20-linux-x64"],
    "outputPath": "dist/bin"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "marked": "^14.1.0",
    "openai": "^4.73.0",
    "ora": "^8.1.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@yao-pkg/pkg": "^5.0.0",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
