{
  "name": "occca",
  "version": "1.0.20",
  "description": "OpenAI Compatible CLI Coding Agent - A minimal agentic coding CLI using OpenAI-compatible APIs",
  "type": "module",
  "main": "dist/entrypoints/cli.js",
  "bin": {
    "occca": "./bin/occca.js"
  },
  "scripts": {
    "dev": "node --no-deprecation --import tsx/esm src/entrypoints/cli.ts",
    "build": "tsc",
    "build:static": "bun build src/entrypoints/cli.ts --compile --outfile dist/bin/occca",
    "build:static:win-x64": "bun build src/entrypoints/cli.ts --compile --target=bun-windows-x64 --outfile dist/bin/occca-win-x64.exe",
    "build:static:win-arm64": "bun build src/entrypoints/cli.ts --compile --target=bun-windows-arm64 --outfile dist/bin/occca-win-arm64.exe",
    "build:static:linux-x64": "bun build src/entrypoints/cli.ts --compile --target=bun-linux-x64 --outfile dist/bin/occca-linux-x64",
    "build:static:linux-arm64": "bun build src/entrypoints/cli.ts --compile --target=bun-linux-arm64 --outfile dist/bin/occca-linux-arm64",
    "start": "node --no-deprecation dist/entrypoints/cli.js",
    "preview": "tsx src/entrypoints/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "coding-agent",
    "openai",
    "ai",
    "developer-tools"
  ],
  "license": "proprietary",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "marked": "^14.1.0",
    "openai": "^4.73.0",
    "ora": "^8.1.0",
    "strip-ansi": "^7.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
